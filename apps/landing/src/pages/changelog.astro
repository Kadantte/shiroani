---
import BaseLayout from '../layouts/BaseLayout.astro';
import { ChangelogContent } from '../components/ChangelogContent';
import { Footer } from '../components/Footer';
---

<BaseLayout title="Lista zmian · ShiroAni">
  <header class="border-b border-border px-6 py-4">
    <nav class="mx-auto flex max-w-3xl items-center justify-between">
      <a
        href="/"
        class="flex items-center gap-2 rounded-md text-sm text-muted-foreground transition-colors hover:text-foreground focus-visible:ring-2 focus-visible:ring-primary focus-visible:outline-none"
      >
        &larr; Strona główna
      </a>
      <span class="font-display text-sm font-bold">
        Shiro<span class="text-primary">Ani</span>
      </span>
    </nav>
  </header>

  <main class="mx-auto max-w-3xl px-6 py-16">
    <ChangelogContent client:visible />
  </main>

  <Footer client:visible />
</BaseLayout>
