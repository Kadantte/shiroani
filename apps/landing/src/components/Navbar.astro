---
import { currentVersion } from '../lib/releases';

interface Props {
  activeHref?: string;
}

const { activeHref } = Astro.props;
const version = currentVersion();

const links = [
  { num: '01', label: 'Funkcje', href: '/#funkcje' },
  { num: '02', label: 'Podgląd', href: '/#podglad' },
  { num: '03', label: 'Motywy', href: '/#motywy' },
  { num: '04', label: 'Rodzina', href: '/#suite' },
  { num: '05', label: 'Pobierz', href: '/#pobierz' },
  { num: '06', label: 'Zmiany', href: '/changelog' },
];
---

<nav class="nav">
  <div class="nav-inner">
    <a class="logo" href="/">
      <span class="mark"><img src="/assets/mascot-wave.png" alt="" width="44" height="44" decoding="async" /></span>
      <span class="name">ShiroAni<small>SHIRO·ANI · v{version}</small></span>
    </a>
    <div class="nav-links">
      {links.map((l) => (
        <a href={l.href} class={activeHref === l.href ? 'on' : undefined}>
          <span class="num">{l.num}</span>{l.label}
        </a>
      ))}
    </div>
    <div class="nav-right">
      <a class="nav-gh" href="https://github.com/Shironex/shiroani" aria-label="GitHub" target="_blank" rel="noopener noreferrer">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
          <path d="M12 0C5.4 0 0 5.4 0 12c0 5.3 3.4 9.8 8.2 11.4.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.5-1.4-1.3-1.8-1.3-1.8-1.1-.7.1-.7.1-.7 1.2.1 1.8 1.2 1.8 1.2 1.1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.8-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2-.1-.3-.5-1.5.1-3.2 0 0 1-.3 3.3 1.2 1-.3 2-.4 3-.4s2 .1 3 .4c2.3-1.5 3.3-1.2 3.3-1.2.7 1.7.2 2.9.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6C20.6 21.8 24 17.3 24 12c0-6.6-5.4-12-12-12z"/>
        </svg>
      </a>
      <a class="nav-cta" href="/download">Pobierz <span>↗</span></a>
    </div>
  </div>
</nav>
