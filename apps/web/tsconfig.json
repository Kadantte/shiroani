{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    // `jassub` pulls in `abslink`, whose published `.d.ts` files import
    // sibling types with a literal `.ts` extension (e.g. `./types.ts`). That
    // requires this flag for typecheck to succeed — it's a pure type-only
    // concession (noEmit is true, so no actual emit is affected).
    "allowImportingTsExtensions": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shiroani/shared": ["../../packages/shared/src"],
      "@shiroani/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages/shared/src/**/*.spec.ts",
    "../../packages/shared/src/**/*.test.ts",
    "../../packages/shared/src/**/__tests__/**"
  ]
}
