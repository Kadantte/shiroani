{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["vitest/globals", "node"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "outDir": "./dist",
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@shiroani/shared": ["../../packages/shared/src"],
      "@shiroani/shared/*": ["../../packages/shared/src/*"],
      "@shiroani/changelog": ["../../packages/changelog/src"],
      "@shiroani/changelog/*": ["../../packages/changelog/src/*"]
    }
  },
  "include": ["src/**/*", "../../packages/shared/src/**/*", "../../packages/changelog/src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "../../packages/shared/src/**/*.spec.ts",
    "../../packages/shared/src/**/*.test.ts",
    "../../packages/shared/src/**/__tests__/**"
  ]
}
