{
  "name": "@shiroani/web",
  "version": "0.1.0",
  "description": "ShiroAni web frontend",
  "private": true,
  "sideEffects": [
    "**/*.css"
  ],
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
