generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Guild {
  id        String   @id @default(cuid())
  discordId String   @unique @map("discord_id")
  name      String

  // Channels
  welcomeChannelId  String? @map("welcome_channel_id")
  goodbyeChannelId  String? @map("goodbye_channel_id")
  modLogChannelId   String? @map("mod_log_channel_id")
  activityChannelId String? @map("activity_channel_id")

  // Settings
  welcomeMessage String? @map("welcome_message")
  goodbyeMessage String? @map("goodbye_message")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Verification
  verifyChannelId String? @map("verify_channel_id")
  verifyRoleId    String? @map("verify_role_id")
  verifyMessageId String? @map("verify_message_id")

  // XP/Leveling settings
  xpEnabled        Boolean  @default(false) @map("xp_enabled")
  xpCooldown       Int      @default(60) @map("xp_cooldown") // seconds between XP awards
  xpMinAmount      Int      @default(15) @map("xp_min_amount")
  xpMaxAmount      Int      @default(25) @map("xp_max_amount")
  levelUpChannelId String?  @map("level_up_channel_id")

  moderationLogs ModerationLog[]
  reactionRoles  ReactionRole[]
  members        Member[]
  levelRoles     LevelRole[]

  @@map("guilds")
}

enum ModerationAction {
  BAN
  UNBAN
  MUTE
  UNMUTE
  CLEAR_MESSAGES
}

model ModerationLog {
  id      String           @id @default(cuid())
  guildId String           @map("guild_id")
  action  ModerationAction

  targetUserId    String?  @map("target_user_id")
  moderatorId     String  @map("moderator_id")
  reason          String?
  duration        Int? // Duration in seconds (for mutes)
  messagesCleared Int?    @map("messages_cleared") // For clear action

  createdAt DateTime @default(now()) @map("created_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@index([guildId, createdAt])
  @@index([targetUserId])
  @@index([moderatorId])
  @@map("moderation_logs")
}

model ReactionRole {
  id        String @id @default(cuid())
  guildId   String @map("guild_id")
  messageId String @map("message_id")
  channelId String @map("channel_id")
  emoji     String // Unicode emoji or custom emoji ID
  roleId    String @map("role_id")

  createdAt DateTime @default(now()) @map("created_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([messageId, emoji])
  @@index([guildId])
  @@map("reaction_roles")
}

model Member {
  id       String @id @default(cuid())
  guildId  String @map("guild_id")
  userId   String @map("user_id")
  xp       Int    @default(0)
  level    Int    @default(0)
  messages Int    @default(0)
  lastXpAt DateTime? @map("last_xp_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, userId])
  @@index([guildId, xp(sort: Desc)])
  @@map("members")
}

model LevelRole {
  id      String @id @default(cuid())
  guildId String @map("guild_id")
  level   Int
  roleId  String @map("role_id")

  createdAt DateTime @default(now()) @map("created_at")

  guild Guild @relation(fields: [guildId], references: [id], onDelete: Cascade)

  @@unique([guildId, level])
  @@index([guildId])
  @@map("level_roles")
}
