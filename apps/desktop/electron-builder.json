{
  "$schema": "https://raw.githubusercontent.com/electron-userland/electron-builder/master/packages/app-builder-lib/scheme.json",
  "appId": "com.shironex.shiroani",
  "productName": "ShiroAni",
  "directories": {
    "output": "release",
    "buildResources": "resources"
  },
  "files": ["dist/**/*", "package.json", "!**/*.map", "!**/*.d.ts", "!dist/**/*.d.ts"],
  "asarUnpack": ["**/node_modules/better-sqlite3/**", "**/build/Release/*.node"],
  "extraResources": [
    {
      "from": "build/Release/desktop_overlay.node",
      "to": "native/desktop_overlay.node"
    },
    {
      "from": "resources/mascot",
      "to": "mascot"
    },
    {
      "from": "resources/icon.ico",
      "to": "icon.ico"
    }
  ],
  "artifactName": "${productName}-${version}-${arch}.${ext}",
  "nodeGypRebuild": false,
  "npmRebuild": false,
  "publish": {
    "provider": "github",
    "owner": "Shironex",
    "repo": "shiroani"
  },
  "mac": {
    "category": "public.app-category.entertainment",
    "icon": "resources/icon.png",
    "target": ["dmg"]
  },
  "win": {
    "icon": "resources/icon.ico",
    "target": ["nsis"]
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true
  },
  "electronFuses": {
    "runAsNode": false,
    "enableNodeCliInspectArguments": false,
    "enableNodeOptionsEnvironmentVariable": false,
    "onlyLoadAppFromAsar": true
  }
}
