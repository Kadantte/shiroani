{
  "name": "@shiroani/desktop",
  "version": "0.1.0",
  "description": "ShiroAni desktop application",
  "author": {
    "name": "Shironex",
    "email": "support@taketach.pl"
  },
  "homepage": "https://github.com/Shironex/shiroani",
  "private": true,
  "main": "dist/main/index.js",
  "scripts": {
    "predev": "node scripts/native-build.mjs",
    "dev": "tsc -p tsconfig.build.json && cross-env NODE_ENV=development electron .",
    "build:dev": "tsc -p tsconfig.build.json",
    "build": "pnpm native:build && tsc -p tsconfig.build.json && node scripts/copy-renderer.mjs",
    "typecheck": "tsc -p tsconfig.build.json --noEmit",
    "test": "jest",
    "test:cov": "jest --coverage",
    "test:watch": "jest --watch",
    "package": "pnpm build && electron-builder",
    "package:win": "pnpm build && electron-builder --win",
    "package:mac": "pnpm build && electron-builder --mac",
    "native:build": "node scripts/native-build.mjs",
    "native:clean": "node-gyp clean",
    "postinstall": "electron-builder install-app-deps",
    "rebuild": "electron-builder install-app-deps"
  },
  "dependencies": {
    "@ghostery/adblocker-electron": "^2.3.2",
    "@ghostery/adblocker-electron-preload": "^2.3.2",
    "@nestjs/common": "^10.4.22",
    "@nestjs/core": "^10.4.22",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/platform-express": "^10.4.22",
    "@nestjs/platform-socket.io": "^10.4.22",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/websockets": "^10.4.22",
    "@shiroani/shared": "workspace:*",
    "better-sqlite3": "^12.6.2",
    "node-addon-api": "^8.6.0",
    "cross-fetch": "^4.1.0",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "semver": "^7.7.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@nestjs/testing": "^10.4.22",
    "@types/better-sqlite3": "^7.6.12",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.3.5",
    "@types/semver": "^7.7.1",
    "cross-env": "^10.1.0",
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^30.2.0",
    "ts-jest": "^29.4.6"
  }
}
